<% layout("layouts/boilerplate") %>

<section class="profile-page">

    <div class="profile-card">

        <div class="profile-top">

            <img
                src="<%= currUser.profileImage.url %>"
                class="profile-avatar"
                alt="Profile Picture"
            >

            <h1><%= currUser.name %></h1>

            <h3>@<%= currUser.username %></h3>

            <span class="role-badge">

                <%= currUser.role.toUpperCase() %>

            </span>

        </div>

        <div class="profile-info">

            <h2>Personal Information</h2>

            <div class="info-grid">

                <div class="info-box">

                    <h4>Email</h4>

                    <p><%= currUser.email %></p>

                </div>

                <div class="info-box">

                    <h4>Phone</h4>

                    <p><%= currUser.phone %></p>

                </div>

                <div class="info-box">

                    <h4>Gender</h4>

                    <p><%= currUser.gender || "Not Provided" %></p>

                </div>

                <div class="info-box">

                    <h4>Date of Birth</h4>

                    <p>

                        <%= currUser.dateOfBirth ? currUser.dateOfBirth.toDateString() : "Not Provided" %>

                    </p>

                </div>

                <div class="info-box full-width">

                    <h4>Address</h4>

                    <p><%= currUser.address || "Not Provided" %></p>

                </div>

            </div>

        </div>

        <div class="quick-actions">

            <h2>Quick Actions</h2>

            <div class="action-buttons">

                <a href="#" class="action-btn">

                    📅 My Appointments

                </a>

                <a href="#" class="action-btn">

                    ⭐ My Reviews

                </a>

                <a href="/users/profile/edit" class="action-btn">

                    🛠 Edit Profile

                </a>

                <a style="color: white;" href="/users/logout" class="logout-btn">

                    🚪 Logout

                </a>

            </div>

        </div>

    </div>

</section>