<% layout("layouts/boilerplate") %>

<section class="service-show">

    <div class="service-container">

        <!-- Left Side -->

        <div class="service-image">

            <img
                src="<%= service.image.url %>"
                alt="<%= service.serviceName %>"
            >

        </div>

        <!-- Right Side -->

        <div class="service-content">

            <span class="service-category">
                <%= service.category %>
            </span>

            <h1>
                <%= service.serviceName %>
            </h1>

            <div class="rating">

                ⭐⭐⭐⭐⭐

                <span>4.9 (124 Reviews)</span>

            </div>

            <div class="price-duration">

                <div>

                    <h4>Price</h4>

                    <p class="price">
                        ₹ <%= service.price.toLocaleString("en-IN") %>
                    </p>

                </div>

                <div>

                    <h4>Duration</h4>

                    <p>
                        <%= service.duration %> Minutes
                    </p>

                </div>

            </div>

            <div class="description">

                <h3>About this Service</h3>

                <p>

                    <%= service.description %>

                </p>

            </div>

            <div class="features">

                <h3>What's Included</h3>

                <ul>

                    <li>✔ Premium Products</li>

                    <li>✔ Certified Professional Stylist</li>

                    <li>✔ Sanitized Equipment</li>

                    <li>✔ Relaxing Salon Experience</li>

                </ul>

            </div>

            <div class="buttons">

                <a
                    href="/appointments/new/<%= service._id %>"
                    class="book-btn"
                >

                    Book Appointment

                </a>

                <a
                    href="/services/<%= service._id %>/edit"
                    class="edit-btn"
                >

                    Edit Service

                </a>
                <form
                    action="/services/<%= service._id %>?_method=DELETE"
                    method="POST"
                >

                    <button class="delete-btn">

                        Delete Service

                    </button>

                </form>

            </div>

        </div>

    </div>

</section>